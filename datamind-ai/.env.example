# Copia este archivo como .env y rellena tus valores
# cp .env.example .env

# ── ANTHROPIC ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api...

# ── SERVIDOR ─────────────────────────────────────────────────────
PORT=3000

# ── AUTENTICACION JWT ─────────────────────────────────────────────
# CRITICO: Cambia esto por un string aleatorio largo en produccion
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-secreto-aleatorio-largo

# ── USUARIO ADMINISTRADOR INICIAL ─────────────────────────────────
# Solo aplica al PRIMER arranque (cuando data/users.json no existe)
# Despues de creado, cambia la contrasena via la aplicacion
ADMIN_USER=admin
ADMIN_PASS=cambia-esta-contrasena
